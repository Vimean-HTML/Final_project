<div class="toast-wrap" id="toast-wrap"></div>

<!-- ══ BOOK DETAIL MODAL ══ -->
<div class="modal-backdrop-custom" id="book-modal" style="display:none;" onclick="closeModal(event)">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div style="font-size:48px;text-align:center;margin-bottom:16px;" id="modal-emoji">📘</div>
    <div class="modal-title" id="modal-title">Book Title</div>
    <div class="modal-sub" id="modal-author">Author · Category</div>
    <div style="font-size:13.5px;line-height:1.7;color:var(--muted);margin-bottom:20px;" id="modal-desc">Description goes here.</div>
    <div style="display:flex;gap:10px;align-items:center;margin-bottom:20px;">
      <span id="modal-avail" class="badge-ok">Available</span>
      <span style="font-size:12px;color:var(--muted);">ISBN: 978-3-16-148410-0</span>
    </div>
    <div style="display:flex;gap:10px;">
      <button class="btn-primary-modal" id="modal-borrow-btn" onclick="borrowFromModal()">Borrow this book</button>
      <button class="btn-secondary-modal" onclick="document.getElementById('book-modal').style.display='none'">Close</button>
    </div>
  </div>
</div>

<!-- ══ LOGOUT MODAL ══ -->
<div class="modal-backdrop-custom" id="logout-modal" style="display:none;" onclick="closeLogoutModal(event)">
  <div class="modal-box" onclick="event.stopPropagation()">
    <div style="font-size:40px;text-align:center;margin-bottom:16px;">👋</div>
    <div class="modal-title">Sign out?</div>
    <div class="modal-sub">You'll need to sign back in to access your library account.</div>
    <div style="display:flex;gap:10px;">
      <button class="btn-primary-modal" style="background:#dc2626;" onclick="doLogout()">Yes, sign out</button>
      <button class="btn-secondary-modal" onclick="document.getElementById('logout-modal').style.display='none'">Cancel</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script>

/* ── BOOK DATA ── */
const books = [
  {title:'The Lean Startup',author:'Eric Ries',cat:'Business',emoji:'📊',bg:'#fff7ed',available:false,desc:'A methodology for developing businesses and products using lean manufacturing principles.'},
  {title:'Atomic Habits',author:'James Clear',cat:'Business',emoji:'⚡',bg:'#fef3c7',available:true,desc:'Practical strategies for forming good habits, breaking bad ones, and mastering tiny behaviours.'},
  {title:'Sapiens',author:'Yuval Noah Harari',cat:'History',emoji:'🏛️',bg:'#fef3c7',available:false,desc:'A narrative history of humankind from the Stone Age to the modern era.'},
  {title:'Deep Work',author:'Cal Newport',cat:'Business',emoji:'📘',bg:'#ede9fe',available:true,desc:'Rules for focused success in a distracted world — how to produce your best work.'},
  {title:'A Brief History of Time',author:'Stephen Hawking',cat:'Science',emoji:'🔬',bg:'#e0f2fe',available:true,desc:'An exploration of cosmology, from the Big Bang to black holes, written for a general audience.'},
  {title:'The Midnight Library',author:'Matt Haig',cat:'Fiction',emoji:'📖',bg:'#fef3c7',available:true,desc:'Between life and death there is a library — a story about regret, hope, and second chances.'},
  {title:'Clean Code',author:'Robert C. Martin',cat:'Technology',emoji:'💻',bg:'#f0fdf4',available:true,desc:'A handbook of agile software craftsmanship that will help you write better, cleaner code.'},
  {title:'1984',author:'George Orwell',cat:'Fiction',emoji:'👁️',bg:'#fce7f3',available:true,desc:'A dystopian novel set in a totalitarian society ruled by Big Brother.'},
  {title:'Guns, Germs and Steel',author:'Jared Diamond',cat:'History',emoji:'🗺️',bg:'#fef9c3',available:false,desc:'An investigation into why some civilisations came to dominate others.'},
  {title:'The Alchemist',author:'Paulo Coelho',cat:'Fiction',emoji:'🌸',bg:'#fce7f3',available:true,desc:'A philosophical novel about a young shepherd\'s journey to find treasure and purpose.'},
  {title:'Zero to One',author:'Peter Thiel',cat:'Business',emoji:'🚀',bg:'#ede9fe',available:true,desc:'Notes on startups, or how to build the future by creating truly unique companies.'},
  {title:'Python Crash Course',author:'Eric Matthes',cat:'Technology',emoji:'🐍',bg:'#f0fdf4',available:true,desc:'A hands-on, project-based introduction to programming with Python.'},
];

let currentCat = 'All';
let currentSearch = '';
let currentModalBook = null;

function renderBooks(list){
  const grid = document.getElementById('book-grid');
  if(!list.length){
    grid.innerHTML='<div class="col-12"><div class="g-card text-center" style="padding:40px;color:var(--muted);">No books found. Try a different search or filter.</div></div>';
    return;
  }
  grid.innerHTML = list.map(b=>`
    <div class="col-sm-6 col-md-4 col-lg-3">
      <div class="book-card">
        <div class="book-cover" style="background:${b.bg};">${b.emoji}</div>
        <div class="book-body">
          <div class="book-title">${b.title}</div>
          <div class="book-author">${b.author}</div>
          <div><span class="book-category cat-${b.cat.toLowerCase().replace('technology','tech').replace('business','biz')}">${b.cat}</span></div>
          <div style="font-size:11.5px;margin-bottom:10px;">
            <span class="${b.available?'avail-yes':'avail-no'}" style="background:${b.available?'var(--green-bg)':'var(--red-bg)'};color:${b.available?'var(--green)':'var(--red)'};padding:2px 8px;border-radius:10px;">
              ${b.available?'Available':'Borrowed'}
            </span>
          </div>
          <div class="d-flex gap-2 mb-2">
            <button class="btn-borrow" style="font-size:12px;" onclick="openModal('${b.title.replace(/'/g,"\\'")}')">Details</button>
            <button class="btn-fav" onclick="toggleFav(this)"><i class="ti ti-heart"></i></button>
          </div>
          <button class="btn-borrow" ${b.available?'':'disabled'} onclick="borrowBook('${b.title.replace(/'/g,"\\'")}')">
            ${b.available?'Borrow':'Unavailable'}
          </button>
        </div>
      </div>
    </div>
  `).join('');
}

function filterBooks(){
  currentSearch = document.getElementById('catalog-search').value.toLowerCase();
  const filtered = books.filter(b=>{
    const matchCat = currentCat==='All' || b.cat===currentCat;
    const matchSearch = b.title.toLowerCase().includes(currentSearch) || b.author.toLowerCase().includes(currentSearch);
    return matchCat && matchSearch;
  });
  renderBooks(filtered);
}

function setCat(cat, btn){
  currentCat = cat;
  document.querySelectorAll('.filter-pill').forEach(p=>p.classList.remove('active'));
  btn.classList.add('active');
  filterBooks();
}

function liveSearch(val){
  currentSearch = val.toLowerCase();
  filterBooks();
}

/* ── SECTION NAVIGATION ── */
function showSection(id, el){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  if(el) el.classList.add('active');
  const titles = {dashboard:'Dashboard',catalog:'Book Catalog',borrowing:'Borrowing',favorites:'Favorites',notifications:'Notifications',profile:'My Profile'};
  document.getElementById('topbar-title').textContent = titles[id]||'';
  if(id==='catalog') renderBooks(books);
  if(window.innerWidth<=900) document.getElementById('sidebar').classList.remove('open');
}

/* ── BORROW ── */
function borrowBook(title){
  showToast(`📚 Borrow request sent for "${title}"`);
}

/* ── FAVORITES ── */
function toggleFav(btn){
  btn.classList.toggle('active');
  if(btn.classList.contains('active')){
    showToast('❤️ Added to favorites');
  } else {
    showToast('🤍 Removed from favorites');
  }
}

/* ── MODAL ── */
function openModal(title){
  const b = books.find(x=>x.title===title);
  if(!b) return;
  currentModalBook = b;
  document.getElementById('modal-emoji').textContent = b.emoji;
  document.getElementById('modal-title').textContent = b.title;
  document.getElementById('modal-author').textContent = b.author+' · '+b.cat;
  document.getElementById('modal-desc').textContent = b.desc;
  const avail = document.getElementById('modal-avail');
  avail.textContent = b.available?'Available':'Currently borrowed';
  avail.className = b.available?'badge-ok':'badge-due';
  document.getElementById('modal-borrow-btn').disabled = !b.available;
  document.getElementById('book-modal').style.display='flex';
}

function borrowFromModal(){
  if(currentModalBook){
    showToast(`📚 Borrow request sent for "${currentModalBook.title}"`);
    document.getElementById('book-modal').style.display='none';
  }
}

function closeModal(e){
  if(e.target===document.getElementById('book-modal'))
    document.getElementById('book-modal').style.display='none';
}

/* ── LOGOUT ── */
function confirmLogout(){
  document.getElementById('logout-modal').style.display='flex';
}
function closeLogoutModal(e){
  if(e.target===document.getElementById('logout-modal'))
    document.getElementById('logout-modal').style.display='none';
}
function doLogout(){
  document.getElementById('logout-modal').style.display='none';
  showToast('👋 Signed out. Redirecting…');
  setTimeout(()=>{ window.location.href='library-login.html'; },1500);
}

/* ── TOAST ── */
function showToast(msg){
  const wrap = document.getElementById('toast-wrap');
  const div = document.createElement('div');
  div.className='toast-msg';
  div.textContent=msg;
  wrap.appendChild(div);
  setTimeout(()=>div.remove(),3000);
}

/* ── SIDEBAR TOGGLE ── */
function toggleSidebar(){
  document.getElementById('sidebar').classList.toggle('open');
}

/* ── INIT ── */
renderBooks(books);

</script>
</body>
</html>
